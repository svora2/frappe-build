# Copy this file on the server: cp production.env.example ~/gitops/frappelms.env
# Then edit the values marked CHANGE ME below.

# --- Custom image (built by .github/workflows/build-custom-image.yml) ---
CUSTOM_IMAGE=ghcr.io/svora2/frappe-build
CUSTOM_TAG=latest

# --- Database ---
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Gunicorn tuning (defaults are fine to start) ---
GUNICORN_THREADS=4
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120

# --- HTTPS / domain (nginx-proxy + acme-companion overrides) ---
NGINX_PROXY_HOSTS=CHANGE_ME_your-domain.com
LETSENCRYPT_EMAIL=CHANGE_ME_admin@your-domain.com
